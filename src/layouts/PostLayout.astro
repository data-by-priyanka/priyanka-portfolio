---
import { type BlogSchema } from "../content/config";
import BaseLayout from "./BaseLayout.astro";
import dayjs from "dayjs";
import localizedFormat from "dayjs/plugin/localizedFormat";
import { Image } from "astro:assets";

export interface Props extends BlogSchema {}

const {
  title,
  description,
  pubDate,
  updatedDate,
  heroImage,
  badge,
  tags = []
} = Astro.props;

dayjs.extend(localizedFormat);
const displayDate = pubDate ? dayjs(pubDate).format("ll") : null;
---

<BaseLayout 
  title={title} 
  description={description} 
  image={heroImage} 
  ogType="article"
>

  <main class="md:flex md:justify-center">
    <article class="prose prose-lg max-w-[750px] prose-img:mx-auto">

      {heroImage && (
        <Image
          width={750}
          height={422}
          format="webp"
          src={heroImage}
          alt={title}
          class="w-full mb-6 rounded-lg"
        />
      )}

      <h1 class="text-4xl font-bold mb-2">{title}</h1>

      {displayDate && (
        <time class="text-sm opacity-70">
          {displayDate}
        </time>
      )}

      {badge && (
        <div class="badge badge-secondary my-2">
          {badge}
        </div>
      )}

      {tags.length > 0 && (
        <div class="flex flex-wrap gap-2 my-3">
          {tags.map((tag) => (
            <span class="badge badge-outline">
              {tag}
            </span>
          ))}
        </div>
      )}

      {updatedDate && (
        <div class="text-sm opacity-60 mt-1">
          Last updated on {dayjs(updatedDate).format("ll")}
        </div>
      )}

      <div class="divider my-4"></div>

      <slot />

    </article>
  </main>

</BaseLayout>
