---
const {
  title,
  img,
  desc,
  url,
  badge,
  tags = [],
  target = "_blank"
} = Astro.props;

import { Image } from "astro:assets";
---

<div class="md:w-1/3 w-full px-4 py-3">
  <a href={url} target={target} rel="noopener noreferrer">
    <div class="card bg-base-100 hover:shadow-xl transition-all duration-300 hover:scale-[1.02]">
      
      {img && (
        <Image
          src={img}
          alt={title}
          width={750}
          height={422}
          format="webp"
          class="rounded-t-lg"
        />
      )}

      <div class="card-body">
        <h2 class="card-title">
          {title}
          {badge && <span class="badge badge-secondary ml-2">{badge}</span>}
        </h2>

        <p class="text-sm opacity-80">{desc}</p>

        {tags.length > 0 && (
          <div class="card-actions justify-end mt-3">
            {tags.map((tag) => (
              <span class="badge badge-outline">{tag}</span>
            ))}
          </div>
        )}
      </div>

    </div>
  </a>
</div>
