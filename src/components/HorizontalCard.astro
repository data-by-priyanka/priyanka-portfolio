---
const {
  title,
  img,
  desc,
  url,
  badge,
  tags = [],
  target = "_blank"
} = Astro.props;

import { Image } from "astro:assets";
---

<div class="rounded-lg bg-base-100 hover:shadow-xl transition-all duration-300 hover:scale-[1.02]">
  <a href={url} target={target} rel="noopener noreferrer">
    <div class="hero-content flex-col md:flex-row">

      {img && (
        <Image
          src={img}
          width={750}
          height={422}
          format="webp"
          alt={title}
          class="max-w-full md:max-w-[13rem] rounded-lg"
        />
      )}

      <div class="grow w-full">
        <h2 class="text-xl font-bold flex items-center flex-wrap">
          {title}
          {badge && (
            <span class="badge badge-secondary ml-2">
              {badge}
            </span>
          )}
        </h2>

        <p class="py-2 text-sm opacity-80">
          {desc}
        </p>

        {tags.length > 0 && (
          <div class="flex flex-wrap gap-2 mt-2">
            {tags.map((tag) => (
              <span class="badge badge-outline">
                {tag}
              </span>
            ))}
          </div>
        )}
      </div>

    </div>
  </a>
</div>
