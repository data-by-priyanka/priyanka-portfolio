---
import BaseLayout from "../layouts/BaseLayout.astro";
import HorizontalCard from "../components/HorizontalCard.astro";
---

<BaseLayout
  title="Priyanka Mishra | Data Analytics Portfolio"
  description="Portfolio documenting structured learning, projects, and professional growth in Data Analytics."
  sideBarActiveItemID="home"
>

  <!-- Hero Section -->
  <section class="mt-8 mb-16">
    <h1 class="text-4xl font-bold mb-4">
      Priyanka Mishra
    </h1>

    <h2 class="text-xl opacity-80 mb-6">
      Data Analytics Portfolio
    </h2>

    <p class="text-lg leading-relaxed max-w-3xl">
      This website documents my structured transition into Data Analytics
      through disciplined learning, hands-on projects, and continuous
      technical development in SQL, Excel, and data visualization.
    </p>
  </section>

  <!-- Featured Work -->
  <section class="mb-16">
    <h3 class="text-3xl font-semibold mb-6">
      Featured Projects
    </h3>

    <HorizontalCard
      title="Data Analysis Case Study – Coming Soon"
      img="/post_img.webp"
      desc="An end-to-end data analysis project demonstrating structured problem-solving, data cleaning, transformation, and insight generation."
      url="/projects"
      target="_self"
      badge="In Progress"
    />

  </section>

</BaseLayout>