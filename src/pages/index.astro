---
import BaseLayout from "../layouts/BaseLayout.astro";
import HorizontalCard from "../components/HorizontalCard.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog"))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const latestPosts = posts.slice(0, 3);
---

<BaseLayout
  title="Priyanka Mishra | Data Analytics Portfolio"
  description="Portfolio documenting structured learning, projects, and professional growth in Data Analytics."
  sideBarActiveItemID="home"
>

  <!-- Hero Section -->
  <section class="mb-16 mt-6">
    <h1 class="text-4xl font-bold mb-4">
      Priyanka Mishra
    </h1>

    <h2 class="text-xl opacity-80 mb-6">
      Data Analytics Portfolio
    </h2>

    <p class="text-lg leading-relaxed max-w-3xl">
      This platform documents my structured transition into Data Analytics
      through disciplined learning, hands-on projects, and continuous
      technical development in SQL, Excel, and data visualization.
    </p>
  </section>

  <!-- Featured Projects Placeholder -->
  <section class="mb-12">
    <h3 class="text-3xl font-semibold mb-6">
      Featured Projects
    </h3>

    <HorizontalCard
      title="Project Case Study – Coming Soon"
      img="/post_img.webp"
      desc="End-to-end data analysis project demonstrating structured problem-solving, data cleaning, and insight generation."
      url="/projects"
      target="_self"
      badge="In Progress"
    />
  </section>

  <!-- Latest Learning Posts -->
  {latestPosts.length > 0 && (
    <section>
      <h3 class="text-3xl font-semibold mb-6 mt-12">
        Latest Learning Entries
      </h3>

      {latestPosts.map((post) => (
        <>
          <HorizontalCard
            title={post.data.title}
            img={post.data.heroImage}
            desc={post.data.description}
            url={"/blog/" + post.slug}
            target="_self"
            badge={post.data.badge}
          />
          <div class="divider my-0"></div>
        </>
      ))}
    </section>
  )}

</BaseLayout>
