---
import BaseLayout from "../layouts/BaseLayout.astro";
import HorizontalCard from "../components/HorizontalCard.astro";
---

<BaseLayout 
  title="Projects | Priyanka Mishra"
  description="Data analytics case studies and structured projects demonstrating applied SQL, Excel, and business insight development."
  sideBarActiveItemID="projects"
>

  <section class="mb-12 mt-6">
    <h1 class="text-4xl font-bold mb-4">
      Data Analytics Projects
    </h1>

    <p class="text-lg opacity-80 max-w-3xl">
      A curated collection of structured analytics work focused on
      data cleaning, transformation, exploratory analysis, and
      business-driven insight generation.
    </p>
  </section>

  <div class="divider my-6"></div>

  <!-- Project 1 -->
  <HorizontalCard
    title="Fraud Detection Analysis"
    img="/post_img.webp"
    desc="Exploratory analysis of historical transaction data to identify behavioral anomalies, high-risk patterns, and potential fraud indicators."
    url="https://github.com/data-by-priyanka/YOUR-FRAUD-REPO"
    target="_blank"
    badge="Case Study"
    tags={["Excel", "Data Cleaning", "Descriptive Analytics"]}
  />
  <div class="divider my-0"></div>

  <!-- Project 2 -->
  <HorizontalCard
    title="Excel Data Transformation Workflow"
    img="/post_img.webp"
    desc="Structured PDF-to-Excel data transformation using Power Query and advanced formula logic to standardize and clean semi-structured datasets."
    url="https://github.com/data-by-priyanka/YOUR-EXCEL-REPO"
    target="_blank"
    badge="Process Documentation"
    tags={["Excel", "Power Query", "Automation"]}
  />
  <div class="divider my-0"></div>

  <!-- Project 3 -->
  <HorizontalCard
    title="SQL Data Querying Practice"
    img="/post_img.webp"
    desc="Hands-on SQL exercises covering filtering, joins, aggregation, grouping, and business-oriented query development."
    url="https://github.com/data-by-priyanka/YOUR-SQL-REPO"
    target="_blank"
    badge="Skill Development"
    tags={["SQL", "Relational Databases", "Query Optimization"]}
  />

</BaseLayout>
